{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "lsp": "allow",
    "list": "allow",
    "glob": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "doom_loop": "deny",
    "bash": {
      "*": "ask"
    }
  },
  "mcp": {
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    }
  }
}
