{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "color": "#7AFFFD"
    },
    "plan": {
      "color": "#FFF200"
    },
    "webbrowser": {
      "color": "#7383eb"
    },
    "yolo": {
      "color": "#FF0033"
    }
  },
  "permission": {
    "*": "ask",
    "lsp": "allow",
    "list": "allow",
    "glob": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "doom_loop": "deny",
    "bash": {
      "*": "ask"
    }
  },
  "provider": {
     "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://192.168.100.116:1234/v1"
      },
      "models": {
        "granite-4.1-3b": {
	  "name": "Granite 4.1 3B",
          "limit": {
            "context": 64000,
            "output": 8000
          }
	}
      }
    }
  },
  "mcp": {
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    },
    "duckduckgo-search": {
      "type": "local",
      "command": [
        "duckduckgo-mcp-server"
      ]
    },
    "pubmed": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "pubmed-mcp-server"
      ]
    },
    "crossref": {
      "type": "local",
      "command": [
        "crossref-mcp"
      ]
    },
    "semantic-scholar": {
      "type": "local",
      "command": [
        "semanticscholar-mcp"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "playwright-mcp"
      ]
    },
    "browserbase": {
      "type": "local",
      "command": [
        "mcp-server-browserbase"
      ],
      "environment": {
        "BROWSERBASE_API_KEY": "{env:BROWSERBASE_API_KEY}",
        "BROWSERBASE_PROJECT_ID": "{env:BROWSERBASE_PROJECT_ID}"
      }
    },
    "chrome": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp"
      ]
    },
    "youtube": {
      "type": "local",
      "command": [
        "mcp-youtube"
      ],
      "environment": {
        "YOUTUBE_API_KEY": "{env:YOUTUBE_API_KEY}"
      }
    },
    "youtube-transcript": {
      "type": "local",
      "command": [
        "youtube-mcp"
      ]
    }
  }
}
